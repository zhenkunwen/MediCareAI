# ==========================================
# 医智云·AI医疗协作平台 - Environment Configuration
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ==========================================

# --- Application ---
APP_NAME=医智云·AI医疗协作平台
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-64-char-random-string-in-production

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/medicareai
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medicareai
DB_USER=postgres
DB_PASSWORD=postgres

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# --- AI / LLM Providers ---
# OpenAI compatible endpoints
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# GLM (Zhipu)
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Moonshot (Kimi)
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# Alibaba (Qwen)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Default model for general tasks
DEFAULT_LLM_MODEL=gpt-4o-mini

# --- Vector Database (pgvector) ---
VECTOR_DIMENSION=1536

# --- RAG / Reranking ---
RERANKER_PROVIDER=cohere
RERANKER_API_KEY=
RERANKER_TOP_K=5

# --- Email (for notifications) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@medicareai.dev

# --- Monitoring ---
SENTRY_DSN=
PROMETHEUS_PORT=9090

# --- Guest Mode ---
GUEST_SESSION_TTL_HOURS=24
GUEST_MAX_MESSAGES=10
